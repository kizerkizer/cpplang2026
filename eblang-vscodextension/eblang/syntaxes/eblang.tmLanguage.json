{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "English Breakfast",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#modifiers"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#macros"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.eblang",
					"match": "//.*$"
				},
				{
					"name": "comment.block.eblang",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"macros": {
			"patterns": [
				{
					"name": "entity.name.function.macro.eblang",
					"match": "(\")([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "punctuation.definition.macro.eblang" },
						"2": { "name": "entity.name.function.macro.eblang" }
					}
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.eblang",
					"match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
				},
				{
					"name": "constant.numeric.integer.eblang",
					"match": "\\b\\d+([eE][+-]?\\d+)?\\b"
				}
			]
		},
		"modifiers": {
			"patterns": [
				{
					"name": "storage.modifier.eblang",
					"match": "\\b(public|private|protected|internal)\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.eblang",
					"match": "\\b(if|then|else|while|loop|return|continue|break|is)\\b"
				},
				{
					"name": "keyword.declaration.eblang",
					"match": "\\b(var|type|function|method|class|interface|macro|enumeration)\\b"
				},
				{
					"match": "\\b(var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.declaration.eblang" },
						"2": { "name": "variable.other.readwrite.eblang" },
						"3": { "name": "keyword.operator.eblang" },
						"4": { "name": "entity.name.type.eblang" }
					}
				},
				{
					"name": "keyword.operator.eblang",
					"match": "(&{1,2}|\\|{1,2}|!|<|>|<=|>=|==|!=)"
				},
				{
					"name": "entity.name.type.eblang",
					"match": "\\b(Integer|Float|String|Boolean|Void|Empty|Any)\\b"
				},
				{
					"match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)",
					"captures": {
						"1": { "name": "keyword.declaration.eblang" },
						"2": { "name": "entity.name.type.eblang" },
						"3": { "name": "keyword.operator.eblang" }
					}
				},
				{
					"match": "(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.operator.eblang" },
						"2": { "name": "entity.name.type.eblang" }
					}
				}
			]
		},
		"strings": {
			"name": "string.quoted.single.eblang",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape.eblang",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.eblang"
}